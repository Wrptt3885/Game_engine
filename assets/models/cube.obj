# Simple unit cube
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

vn  0  0 -1
vn  0  0  1
vn -1  0  0
vn  1  0  0
vn  0 -1  0
vn  0  1  0

# Back
f 1//1 3//1 2//1
f 1//1 4//1 3//1
# Front
f 5//2 6//2 7//2
f 5//2 7//2 8//2
# Left
f 1//3 8//3 4//3
f 1//3 5//3 8//3
# Right
f 2//4 3//4 7//4
f 2//4 7//4 6//4
# Bottom
f 1//5 2//5 6//5
f 1//5 6//5 5//5
# Top
f 4//6 7//6 3//6
f 4//6 8//6 7//6
